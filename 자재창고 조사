function onOpen() {
  const email = Session.getActiveUser().getEmail();
  const 내계정 = "youngjoonkim@kas.co.kr";

  if (email !== 내계정) return;

  SpreadsheetApp.getUi()
    .createMenu('🔧 자재창고 관리')
    .addItem('📸 사진 URL 업데이트', 'insertImageLinks')
    .addSeparator()
