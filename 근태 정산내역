function getLastDayOfMonth(year, month) {
  return new Date(year, month, 0).getDate();
}

function colIndexToLetter(colIndex) {
  let letter = '';
  let n = colIndex;
  while (n > 0) {
    const remainder = (n - 1) % 26;
    letter = String.fromCharCode(65 + remainder) + letter;
    n = Math.floor((n - 1) / 26);
  }
  return letter;
}

function applyColumnVisibility(sheet, lastDay) {
  const COL_C = 3;
  const COL_AG = 33;
  sheet.showColumns(COL_C, COL_AG - COL_C + 1);
  const lastUsedCol = COL_C + lastDay - 1;
  const hideStartCol = lastUsedCol + 1;
  const hideCount = COL_AG - lastUsedCol;
  if (hideCount > 0) sheet.hideColumns(hideStartCol, hideCount);
}

function getLeaveHistoryTarget(month) {
  const rowMap = { 1:4, 2:10, 3:16, 4:22, 5:28, 6:34, 7:4, 8:10, 9:16, 10:22, 11:28, 12:34 };
  const row = rowMap[month];
  const dataStartCol = month <= 6 ? 4 : 18;
  if (!row) throw new Error(`월 매핑을 찾을 수 없습니다: ${month}월`);
  return { row, dataStartCol };
}

function loadSourceData(targetMonth) {
  const SOURCE_SS_ID = '12yP7AxfC_27B6LhSEJ4lFH5ZYnymyQIlcbPXXhpDUBY';
  const sourceSS = SpreadsheetApp.openById(SOURCE_SS_ID);
  const sourceSheet = sourceSS.getSheetByName(`${targetMonth}월`);
  if (!sourceSheet) throw new Error(`근무계획 스프레드시트에서 "${targetMonth}월" 시트를 찾을 수 없습니다.`);

  const srcDateRow = sourceSheet.getRange('G3:AK3').getValues()[0];
  const srcNameCol = sourceSheet.getRange('C5:C20').getValues();
  const srcDataGrid = sourceSheet.getRange('G5:AK20').getValues();
  const srcBgGrid = sourceSheet.getRange('G5:AK20').getBackgrounds();

  const srcNameMap = {};
  for (let i = 0; i < srcNameCol.length; i++) {
    const raw = srcNameCol[i][0];
    const nameKey = (raw == null ? '' : String(raw)).replace(/\s/g, '');
    if (nameKey === '합계' || nameKey === '') break;
    srcNameMap[nameKey] = i;
  }

  const srcDateMap = {};
  for (let c = 0; c < srcDateRow.length; c++) {
    const d = Number(srcDateRow[c]);
    if (!isNaN(d) && d > 0) srcDateMap[d] = c;
  }

  return { srcNameMap, srcDateMap, srcDataGrid, srcBgGrid };
}

function writeToSheet({ sheet, srcNameMap, srcDateMap, srcDataGrid, srcBgGrid, nameStartRow, nameMaxRow, dataStartCol }) {
  const destNames = readWorkerNames(sheet, nameStartRow, nameMaxRow);
  const destDateRow = sheet.getRange('C5:AG5').getValues()[0];

  const destDateMap = {};
  for (let c = 0; c < destDateRow.length; c++) {
    const d = Number(destDateRow[c]);
    if (!isNaN(d) && d > 0) destDateMap[d] = c;
  }

  const safeLastRow = getDataLastRow(sheet, nameStartRow, nameMaxRow);
  const clearRows = safeLastRow - nameStartRow + 1;
  if (clearRows > 0) {
    const clearRange = sheet.getRange(nameStartRow, dataStartCol, clearRows, destDateRow.length);
    clearRange.clearContent();
    clearRange.setBackground('#ffffff');
  }

  let updated = 0;
  let skipped = 0;
  const log = [];

  for (const { name, rowIndex } of destNames) {
    const nameKey = name.replace(/\s/g, '');
    if (!(nameKey in srcNameMap)) {
      log.push(` ⚠️ "${name}" → 근무계획에 없음`);
      skipped++;
      continue;
    }
    const srcRowIdx = srcNameMap[nameKey];

    for (const [dateStr, destColIdx] of Object.entries(destDateMap)) {
      const day = Number(dateStr);
      if (!(day in srcDateMap)) continue;
      const srcColIdx = srcDateMap[day];
      const cellValue = srcDataGrid[srcRowIdx][srcColIdx];
      const strVal = (cellValue == null || cellValue === '') ? '' : String(cellValue).trim();
      const destRow = nameStartRow + rowIndex;
      const destCol = dataStartCol + destColIdx;

      sheet.getRange(destRow, destCol).setValue(strVal);

      if (strVal === '교' && srcBgGrid) {
        const srcBg = srcBgGrid[srcRowIdx][srcColIdx];
        if (srcBg && srcBg.toLowerCase() === '#ffff00') {
          sheet.getRange(destRow, destCol).setBackground('#ffff00');
        }
      }

      updated++;
    }
  }

  SpreadsheetApp.flush();
  return { updated, skipped, log };
}

function readWorkerNames(sheet, startRow, maxRow) {
  const result = [];
  for (let row = startRow; row <= maxRow; row++) {
    const rawB = sheet.getRange(row, 2).getValue();
    const rawA = sheet.getRange(row, 1).getValue();
    const keyB = (rawB == null ? '' : String(rawB)).replace(/\s/g, '');
    const keyA = (rawA == null ? '' : String(rawA)).replace(/\s/g, '');
    if (keyA === '합계' || keyB === '합계') break;
    if (keyA === '' && keyB === '') break;
    const nameRaw = rawB !== '' && rawB != null ? rawB : rawA;
    result.push({ name: String(nameRaw).trim(), rowIndex: row - startRow });
  }
  return result;
}

function getAttendSumRow(sheet, startRow, maxRow) {
  for (let row = startRow; row <= maxRow; row++) {
    const val = sheet.getRange(row, 1).getValue();
    const key = (val == null ? '' : String(val)).replace(/\s/g, '');
    if (key === '계' || key === '합계') return row;
  }
  return maxRow;
}

function getDataLastRow(sheet, nameStartRow, nameMaxRow) {
  for (let row = nameStartRow; row <= nameMaxRow; row++) {
    const valA = sheet.getRange(row, 1).getValue();
    const valB = sheet.getRange(row, 2).getValue();
    const keyA = (valA == null ? '' : String(valA)).replace(/\s/g, '');
    const keyB = (valB == null ? '' : String(valB)).replace(/\s/g, '');
    if (keyA === '합계' || keyB === '합계') return row - 1;
  }
  return nameMaxRow;
}

function findSheetByPattern(ss, pattern) {
  for (const s of ss.getSheets()) {
    if (pattern.test(s.getName().trim())) return s.getName();
  }
  return null;
}

function validateMonth(month, rawValue) {
  if (!month || isNaN(month) || month < 1 || month > 12) {
    throw new Error(`Z3 셀의 월 값이 올바르지 않습니다: "${rawValue}"`);
  }
}

/**
 * "X월 근무현황표" 시트의 Z3(월)/X3(년도) 반환 (기존 기본 동작)
 */
function getCurrentYearMonth(ss) {
  const statusSheetName = findSheetByPattern(ss, /^\d+월 근무현황표$/);
  if (!statusSheetName) throw new Error('"X월 근무현황표" 시트를 찾을 수 없습니다.');
  const statusSheet = ss.getSheetByName(statusSheetName);
  const month = Number(statusSheet.getRange('Z3').getValue());
  const year = Number(statusSheet.getRange('X3').getValue());
  validateMonth(month, month);
  if (!year || isNaN(year)) throw new Error('X3 셀의 년도 값이 올바르지 않습니다.');
  return { year, month };
}

/**
 * 🆕 활성 시트가 "차월 근무계획"이면 그 시트 자체의 Z3(월)를 기준으로 사용.
 * X3(년도)가 없으면 "X월 근무현황표"의 월과 비교해 자동으로 연도를 추정.
 * 그 외 시트에서는 기존처럼 "X월 근무현황표" 기준(getCurrentYearMonth)을 사용.
 */
function resolveYearMonthForActiveSheet(destSS, activeSheet) {
  if (activeSheet && /^차월 근무계획$/.test(activeSheet.getName().trim())) {
    const month = Number(activeSheet.getRange('Z3').getValue());
    validateMonth(month, activeSheet.getRange('Z3').getValue());

    const rawYear = Number(activeSheet.getRange('X3').getValue());
    let year;
    if (rawYear && !isNaN(rawYear)) {
      year = rawYear;
    } else {
      const statusSheetName = findSheetByPattern(destSS, /^\d+월 근무현황표$/);
      if (statusSheetName) {
        const statusSheet = destSS.getSheetByName(statusSheetName);
        const curMonth = Number(statusSheet.getRange('Z3').getValue());
        const curYear = Number(statusSheet.getRange('X3').getValue());
        year = (curYear && !isNaN(curYear))
          ? (month < curMonth ? curYear + 1 : curYear)
          : new Date().getFullYear();
      } else {
        year = new Date().getFullYear();
      }
    }
    return { year, month };
  }
  return getCurrentYearMonth(destSS);
}

