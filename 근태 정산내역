function updateLeaveHistory() {
  const ui = SpreadsheetApp.getUi();
  try {
    const destSS = SpreadsheetApp.getActiveSpreadsheet();

    const statusSheetName = findSheetByPattern(destSS, /^\d+월 근무현황표$/);
    if (!statusSheetName) throw new Error('"X월 근무현황표" 시트를 찾을 수 없습니다.');
    const currentMonth = Number(destSS.getSheetByName(statusSheetName).getRange('Z3').getValue());
    validateMonth(currentMonth, currentMonth);

    const attendSheetName = findSheetByPattern(destSS, new RegExp(`^${currentMonth}월 근태$`));
    if (!attendSheetName) throw new Error(`"${currentMonth}월 근태" 시트를 찾을 수 없습니다.`);
    const attendSheet = destSS.getSheetByName(attendSheetName);
    const valM23 = attendSheet.getRange('M23').getValue();
    const valO23 = attendSheet.getRange('O23').getValue();
    const valK23 = attendSheet.getRange('K23').getValue();

    const leaveSheetName = findSheetByPattern(destSS, /^휴무 소진내역$/);
    if (!leaveSheetName) throw new Error('"휴무 소진내역" 시트를 찾을 수 없습니다.');
    const leaveSheet = destSS.getSheetByName(leaveSheetName);

    const { row, dataStartCol } = getLeaveHistoryTarget(currentMonth);
    [valM23, valO23, valK23, valM23, valO23].forEach((v, i) => {
      leaveSheet.getRange(row, dataStartCol + i).setValue(v);
    });

    SpreadsheetApp.flush();
    ui.alert(
      `📋 휴무 소진내역 업데이트 완료\n\n` +
      `• 대상: ${currentMonth}월 (${row}행)\n` +
      `• M23(연차실시): ${valM23}\n` +
      `• O23(공휴실시): ${valO23}\n` +
      `• K23(주휴실시): ${valK23}`
    );

  } catch (e) {
    ui.alert('❌ 오류 발생\n\n' + e.message);
    console.error(e);
  }
}

