    .addToUi();
}

// =====================================================================
//  🔄 Z3 셀 변경 시 시트 이름 자동 변경
// =====================================================================

function onEdit(e) {
  const range = e.range;
  const sheet = range.getSheet();
  const ss    = e.source;

  if (range.getRow() !== 3 || range.getColumn() !== 26) return;
  if (!/^\d+월 근무현황표$/.test(sheet.getName().trim())) return;

  const newMonth = Number(range.getValue());
  if (!newMonth || isNaN(newMonth) || newMonth < 1 || newMonth > 12) {
    ss.toast(`⚠️ Z3 셀 값이 올바르지 않습니다: "${range.getValue()}" (1~12 사이 숫자 입력)`, '근태관리', 5);
    return;
  }

  const targetPatterns = [
    { pattern: /^\d+월 결과보고$/,   newName: `${newMonth}월 결과보고`   },
    { pattern: /^\d+월 근태$/,       newName: `${newMonth}월 근태`       },
    { pattern: /^\d+월 근무현황표$/, newName: `${newMonth}월 근무현황표` },
  ];

  const logs = [];
  for (const target of targetPatterns) {
    const found = findSheetByPattern(ss, target.pattern);
    if (!found) { logs.push(`⚠️ 패턴 시트 없음 — 건너뜀`); continue; }
    if (found.trim() === target.newName) { logs.push(`ℹ️ [${found}] 이미 같은 이름`); continue; }
    ss.getSheetByName(found).setName(target.newName);
    logs.push(`✅ "${found}" → "${target.newName}"`);
  }

  ss.toast(`🔄 ${newMonth}월로 시트 이름 변경 완료\n` + logs.join(' / '), '근태관리', 5);
}

// =====================================================================
//  🚀 올인원 원터치 실행
// =====================================================================

function runAllInOne() {
  const ui     = SpreadsheetApp.getUi();
  const destSS = SpreadsheetApp.getActiveSpreadsheet();
  const logs   = [];

  try {
    // ── 공통: 월/년도/일수 정보 읽기 ────────────────────────────────
    const statusSheetName = findSheetByPattern(destSS, /^\d+월 근무현황표$/);
    if (!statusSheetName) throw new Error('"X월 근무현황표" 시트를 찾을 수 없습니다.');
    const statusSheet  = destSS.getSheetByName(statusSheetName);
    const currentMonth = Number(statusSheet.getRange('Z3').getValue());
    const currentYear  = Number(statusSheet.getRange('X3').getValue());
    validateMonth(currentMonth, statusSheet.getRange('Z3').getValue());
    if (!currentYear || isNaN(currentYear)) throw new Error(`X3 셀의 년도 값이 올바르지 않습니다: "${statusSheet.getRange('X3').getValue()}"`);

    const nextMonth   = (currentMonth % 12) + 1;
    const nextYear    = nextMonth === 1 ? currentYear + 1 : currentYear;
    const currentDays = getLastDayOfMonth(currentYear, currentMonth);
    const nextDays    = getLastDayOfMonth(nextYear, nextMonth);

    logs.push(`📅 ${currentYear}년 ${currentMonth}월 (${currentDays}일까지) / 차월: ${nextYear}년 ${nextMonth}월 (${nextDays}일까지)`);

    // ── STEP 1. 당월 근무계획 가져오기 ──────────────────────────────
    logs.push('[ STEP 1 ] 당월 근무계획 가져오기');
    const srcCurrent = loadSourceData(currentMonth);
    const currentTargets = [
      { sheetName: statusSheetName,                              nameStartRow: 8, nameMaxRow: 23, dataStartCol: 3 },
      { sheetName: findSheetByPattern(destSS, /^간식정산$/),     nameStartRow: 8, nameMaxRow: 17, dataStartCol: 3 },
      { sheetName: findSheetByPattern(destSS, /^연장야근정산$/), nameStartRow: 8, nameMaxRow: 23, dataStartCol: 3 },
    ];
    for (const target of currentTargets) {
      if (!target.sheetName) { logs.push('  ⚠️ 시트 없음 — 건너뜀'); continue; }
      const sheet = destSS.getSheetByName(target.sheetName);
      const { updated, skipped, log } = writeToSheet({
        sheet,
        srcNameMap:   srcCurrent.srcNameMap,
        srcDateMap:   srcCurrent.srcDateMap,
        srcDataGrid:  srcCurrent.srcDataGrid,
        nameStartRow: target.nameStartRow,
        nameMaxRow:   target.nameMaxRow,
        dataStartCol: target.dataStartCol,
      });
      logs.push(`  ✅ [${target.sheetName}] ${updated}개 입력` + (skipped > 0 ? ` / ${skipped}명 미매칭` : ''));
      logs.push(...log);
      applyColumnVisibility(sheet, currentDays);
      logs.push(`  📐 [${target.sheetName}] ${currentDays}일 이후 열 숨김 처리`);
    }

    // ── STEP 2. 차월 근무계획 가져오기 ──────────────────────────────
    logs.push('[ STEP 2 ] 차월 근무계획 가져오기');
    const nextSheetName = findSheetByPattern(destSS, /^차월 근무계획$/);
    if (!nextSheetName) {
      logs.push('  ⚠️ "차월 근무계획" 시트 없음 — 건너뜀');
    } else {
      const srcNext = loadSourceData(nextMonth);
      const { updated, skipped, log } = writeToSheet({
        sheet:        destSS.getSheetByName(nextSheetName),
        srcNameMap:   srcNext.srcNameMap,
        srcDateMap:   srcNext.srcDateMap,
        srcDataGrid:  srcNext.srcDataGrid,
        nameStartRow: 8,
        nameMaxRow:   23,
        dataStartCol: 3,
      });
      logs.push(`  ✅ [${nextSheetName}] ${updated}개 입력` + (skipped > 0 ? ` / ${skipped}명 미매칭` : ''));
      logs.push(...log);
      applyColumnVisibility(destSS.getSheetByName(nextSheetName), nextDays);
      logs.push(`  📐 [${nextSheetName}] ${nextDays}일 이후 열 숨김 처리`);
    }

    // ── STEP 3. 특수문자 외 → 1: 근무현황표(당월) + 차월 근무계획 ──
    logs.push('[ STEP 3 ] 특수문자 외 → 1');
    const specialList_AG23 = ["휴", "무", "공", "년", "야", "퇴", "사", "상", "반"];
    const step3Targets = [
      { sheetName: statusSheetName, days: currentDays },
      { sheetName: nextSheetName,   days: nextDays    },
    ];
    for (const t of step3Targets) {
      if (!t.sheetName) { logs.push('  ⚠️ 시트 없음 — 건너뜀'); continue; }
      const sheet = destSS.getSheetByName(t.sheetName);
      if (!sheet)  { logs.push(`  ⚠️ [${t.sheetName}] 시트 없음 — 건너뜀`); continue; }
      const endCol = colIndexToLetter(2 + t.days);
      processFillOne(sheet.getRange(`C8:${endCol}23`), specialList_AG23, true);
      logs.push(`  ✅ [${t.sheetName}] C8:${endCol}23 완료 (${t.days}일)`);
    }

    // ── STEP 4. 특수 외 → 1 (당월 일수 기준): 간식정산 ─────────────
    logs.push('[ STEP 4 ] 특수 외 → 1 — 간식정산');
    const snackSheetName = findSheetByPattern(destSS, /^간식정산$/);
    if (!snackSheetName) {
      logs.push('  ⚠️ "간식정산" 시트 없음 — 건너뜀');
    } else {
      const endCol = colIndexToLetter(2 + currentDays);
      processFillOne(
        destSS.getSheetByName(snackSheetName).getRange(`C8:${endCol}17`),
        ["휴", "공", "야", "퇴", "무", "년", "사", "상", "반"],
        true
      );
      logs.push(`  ✅ [${snackSheetName}] C8:${endCol}17 완료 (${currentDays}일)`);
    }

    // ── STEP 5. PBL→연 & 연/야 외 지우기 (당월 일수 기준): 연장야근정산
    logs.push('[ STEP 5 ] PBL→연 & 연/야 외 지우기 — 연장야근정산');
    const overtimeSheetName = findSheetByPattern(destSS, /^연장야근정산$/);
    if (!overtimeSheetName) {
      logs.push('  ⚠️ "연장야근정산" 시트 없음 — 건너뜀');
    } else {
      const nightText = processPBLtoYeonAndClear(destSS.getSheetByName(overtimeSheetName), currentDays);
      const endCol    = colIndexToLetter(2 + currentDays);
      logs.push(`  ✅ [${overtimeSheetName}] C8:${endCol}23 완료 / AD27: ${nightText}`);
    }

    // ── STEP 6. 누계처리: X월 근태 ──────────────────────────────────
    logs.push('[ STEP 6 ] 누계처리 (K→L, M→N, O→P) — X월 근태');
    const attendSheetName = findSheetByPattern(destSS, new RegExp(`^${currentMonth}월 근태$`));
    if (!attendSheetName) {
      logs.push(`  ⚠️ "${currentMonth}월 근태" 시트 없음 — 건너뜀`);
    } else {
      const { updatedCount, skippedCount } = processAccumulate(destSS.getSheetByName(attendSheetName));
      logs.push(`  ✅ [${attendSheetName}] ${updatedCount}개 업데이트 / ${skippedCount}개 건너뜀`);
    }

    // ── STEP 7. 휴무 소진내역 업데이트 ──────────────────────────────
    logs.push('[ STEP 7 ] 휴무 소진내역 업데이트');
    const leaveSheetName = findSheetByPattern(destSS, /^휴무 소진내역$/);
    if (!leaveSheetName) {
      logs.push('  ⚠️ "휴무 소진내역" 시트 없음 — 건너뜀');
    } else if (!attendSheetName) {
      logs.push(`  ⚠️ "${currentMonth}월 근태" 시트 없음 — 건너뜀`);
    } else {
      const { row, dataStartCol } = getLeaveHistoryTarget(currentMonth);
      const attendSheet = destSS.getSheetByName(attendSheetName);
      const valM23      = attendSheet.getRange('M23').getValue();
      const valO23      = attendSheet.getRange('O23').getValue();
      const valK23      = attendSheet.getRange('K23').getValue();
      const leaveSheet  = destSS.getSheetByName(leaveSheetName);
      [valM23, valO23, valK23, valM23, valO23].forEach((v, i) => {
        leaveSheet.getRange(row, dataStartCol + i).setValue(v);
      });
      SpreadsheetApp.flush();
      logs.push(`  ✅ [${leaveSheetName}] ${currentMonth}월 ${row}행 업데이트 완료`);
    }

    // ── 완료 알림 ────────────────────────────────────────────────────
    ui.alert(
      `🚀 올인원 원터치 실행 완료 (${currentYear}년 ${currentMonth}월)\n\n` +
      logs.join('\n')
    );

  } catch (e) {
    ui.alert('❌ 오류 발생\n\n' + e.message + '\n\n--- 진행 로그 ---\n' + logs.join('\n'));
    console.error(e);
  }
}

// =====================================================================
//  📄 결과보고 Google Docs 생성
// =====================================================================

function createReportDoc() {
  const ui = SpreadsheetApp.getUi();
  try {
    const destSS = SpreadsheetApp.getActiveSpreadsheet();

    // ── 년도/월 읽기 ─────────────────────────────────────────────────
    const statusSheetName = findSheetByPattern(destSS, /^\d+월 근무현황표$/);
    if (!statusSheetName) throw new Error('"X월 근무현황표" 시트를 찾을 수 없습니다.');
    const statusSheet  = destSS.getSheetByName(statusSheetName);
    const currentMonth = Number(statusSheet.getRange('Z3').getValue());
    const currentYear  = Number(statusSheet.getRange('X3').getValue());
    validateMonth(currentMonth, statusSheet.getRange('Z3').getValue());
    if (!currentYear || isNaN(currentYear)) throw new Error('X3 셀의 년도 값이 올바르지 않습니다.');

    const nextMonth = (currentMonth % 12) + 1;
    const nextYear  = nextMonth === 1 ? currentYear + 1 : currentYear;
    const YY        = String(currentYear).slice(2);
    const nextYY    = String(nextYear).slice(2);
    const YYYY      = String(currentYear);

    // ── 1. X월 결과보고 A12:M12 — getDisplayValues() 로 서식 그대로 ─
    const resultSheetName = findSheetByPattern(destSS, /^\d+월 결과보고$/);
    if (!resultSheetName) throw new Error('"X월 결과보고" 시트를 찾을 수 없습니다.');
    const workRow = destSS.getSheetByName(resultSheetName)
                          .getRange('A12:M12').getDisplayValues()[0];

    // ── 2. 휴무 소진내역 X월 행 + 누계 행 ───────────────────────────
    const leaveSheetName = findSheetByPattern(destSS, /^휴무 소진내역$/);
    if (!leaveSheetName) throw new Error('"휴무 소진내역" 시트를 찾을 수 없습니다.');
    const leaveSheet        = destSS.getSheetByName(leaveSheetName);
    const { row: leaveRow } = getLeaveHistoryTarget(currentMonth);
    // getDisplayValues() → 백분율(5%, 100%) 서식 그대로
    const leaveMonthRow = leaveSheet.getRange(leaveRow,     2, 1, 13).getDisplayValues()[0];
    const leaveCumRow   = leaveSheet.getRange(leaveRow + 1, 2, 1, 13).getDisplayValues()[0];

    // ── 3. 연장근무 발생 보고 C16:G20 ───────────────────────────────
    const overtimeReportName = findSheetByPattern(destSS, /^연장근무 발생 보고$/);
    if (!overtimeReportName) throw new Error('"연장근무 발생 보고" 시트를 찾을 수 없습니다.');
    // getDisplayValues() → 80.00, -28%, 소수점 서식 그대로
    const overtimeData = destSS.getSheetByName(overtimeReportName)
                               .getRange('C16:G20').getDisplayValues();

    // ── 4. 교통비 지급 정산서 C3:D6 ─────────────────────────────────
    const TRAFFIC_SS_ID = '16z8tsSrWuu7rd1ViJUIAU9odqCQJrUSiImCBENLfek8';
    const trafficSheet  = SpreadsheetApp.openById(TRAFFIC_SS_ID)
                                        .getSheetByName('교통비 발생 내역');
    if (!trafficSheet) throw new Error('교통비 지급 정산서에서 "교통비 발생 내역" 시트를 찾을 수 없습니다.');
    // getDisplayValues() → 188,820 천단위 콤마 서식 그대로
    const trafficData = trafficSheet.getRange('C3:D6').getDisplayValues();

    // ── 5. 차월 근무계획 BK12 (12행만) ──────────────────────────────
    const nextPlanSheetName = findSheetByPattern(destSS, /^차월 근무계획$/);
    if (!nextPlanSheetName) throw new Error('"차월 근무계획" 시트를 찾을 수 없습니다.');
    // BK11:BR11 — 11행만 가져오기
    const nextPlanRow = destSS.getSheetByName(nextPlanSheetName)
                              .getRange('BK11:BR11').getDisplayValues()[0];

    // ── 템플릿 복사 → 새 Docs 파일 생성 ────────────────────────────
    const TEMPLATE_ID = '1Q9wBfik-DWFxBsFc6V4FZ9P0Gr2-xIvJsd0O0Xdt9fE';
    const docTitle    = `[보고] 생수공장 ${YY}년 ${currentMonth}월 근무실적 및 ${nextYY}년 ${nextMonth}월 계획`;
    const newDoc      = DriveApp.getFileById(TEMPLATE_ID).makeCopy(docTitle);
    const doc         = DocumentApp.openById(newDoc.getId());
    const body        = doc.getBody();

    // ── 플레이스홀더 텍스트 치환 ────────────────────────────────────
    // YYYY/nextYYYY 먼저, YY/nextYY 나중에 (부분 치환 방지)
    body.replaceText('\\{\\{YYYY\\}\\}',     YYYY);
    body.replaceText('\\{\\{nextYY\\}\\}',   nextYY);
    body.replaceText('\\{\\{YY\\}\\}',       YY);
    body.replaceText('\\{\\{X\\+1\\}\\}',    String(nextMonth));
    body.replaceText('\\{\\{X\\}\\}',        String(currentMonth));

    // ── 표 데이터 채우기 ─────────────────────────────────────────────
    const tables = body.getTables();

    // 표 1: X월 근무내역 — 마지막 행에 A12:M12
    fillTableLastRow(tables[0], workRow);

    // 표 2: 휴무 소진내역 — 마지막 두 행에 X월행 + 누계행
    fillTableLastTwoRows(tables[1], leaveMonthRow, leaveCumRow);

    // 표 3: 연장 발생내역 — 2번째 행 2번째 열부터 C16:G20 (5행 x 5열)
    fillTableBlock(tables[2], overtimeData, 1, 1);

    // 표 4: 교통비 발생 내역 — 2번째 행 2번째 열부터 C3:D6 (4행 x 2열)
    fillTableBlock(tables[3], trafficData, 1, 1);

    // 표 5: 차월 근무계획 — 마지막 행에 BK12:BR12
    fillTableLastRow(tables[4], nextPlanRow);

    doc.saveAndClose();

    ui.alert(
      `📄 결과보고 Docs 생성 완료\n\n` +
      `• 파일명: ${docTitle}\n` +
      `• URL: ${newDoc.getUrl()}\n\n` +
      `Google Drive에서 확인하세요.`
    );

  } catch (e) {
    ui.alert('❌ 오류 발생\n\n' + e.message);
    console.error(e);
  }
}

// =====================================================================
//  🔧 Docs 표 채우기 유틸 함수들
// =====================================================================

/**
 * 표의 마지막 행 전체에 values 배열 값을 순서대로 채워넣기
 */
function fillTableLastRow(table, values) {
  const row = table.getRow(table.getNumRows() - 1);
  for (let c = 0; c < values.length && c < row.getNumCells(); c++) {
    row.getCell(c).setText(String(values[c]));
  }
}

/**
 * 표의 마지막 두 행에 각각 row1Values, row2Values 채워넣기
 */
function fillTableLastTwoRows(table, row1Values, row2Values) {
  const totalRows = table.getNumRows();
  const row1      = table.getRow(totalRows - 2);
  const row2      = table.getRow(totalRows - 1);
  for (let c = 0; c < row1Values.length && c < row1.getNumCells(); c++) {
    row1.getCell(c).setText(String(row1Values[c]));
  }
  for (let c = 0; c < row2Values.length && c < row2.getNumCells(); c++) {
    row2.getCell(c).setText(String(row2Values[c]));
  }
}

/**
 * 표의 특정 위치(startRow, startCol)부터 2D 배열 데이터 채워넣기
 */
function fillTableBlock(table, data, startRow, startCol) {
  for (let r = 0; r < data.length; r++) {
    const rowIdx = startRow + r;
    if (rowIdx >= table.getNumRows()) break;
    const row = table.getRow(rowIdx);
    for (let c = 0; c < data[r].length; c++) {
      const colIdx = startCol + c;
      if (colIdx >= row.getNumCells()) break;
      row.getCell(colIdx).setText(String(data[r][c]));
    }
  }
}

