function fillKeunTaeData() {
  try {
    const keunTaeSS = SpreadsheetApp.getActiveSpreadsheet();
    let keunTaeSheet = null;
    for (const s of keunTaeSS.getSheets()) {
      if (s.getName().includes('근무현황표')) { keunTaeSheet = s; break; }
    }
    if (!keunTaeSheet) throw new Error('근무현황표 시트를 찾을 수 없습니다.');

    const month = Number(keunTaeSheet.getRange('Z3').getValue());
    if (!month || isNaN(month)) throw new Error('Z3 셀에서 월 값을 읽을 수 없습니다.');

    const workSS = SpreadsheetApp.openById('12yP7AxfC_27B6LhSEJ4lFH5ZYnymyQIlcbPXXhpDUBY');
    let workSheet = null;
    for (const s of workSS.getSheets()) {
      if (s.getName().includes(month + '월')) { workSheet = s; break; }
    }
    if (!workSheet) throw new Error(
      `${month}월 근무계획 시트를 찾을 수 없습니다.\n` +
      `시트 목록: ${workSS.getSheets().map(s => s.getName()).join(', ')}`
    );

    const workData = workSheet.getRange('G3:AK20').getValues();
    const dateRow = workData[0];
    const staffRows = workData.slice(2);

    const prodSS = SpreadsheetApp.openById('1ibZaOX0NKni6vRTVE0i2Wb5AXNHn9D72F5CFWSxH3qQ');
    let prodSheet = null;
    for (const s of prodSS.getSheets()) {
      const name = s.getName();
      if (name.includes(month + '월') && name.includes('제품생산 계획')) {
        prodSheet = s; break;
      }
    }
    if (!prodSheet) throw new Error(
      `${month}월 제품생산 계획 시트를 찾을 수 없습니다.\n` +
      `시트 목록: ${prodSS.getSheets().map(s => s.getName()).join(', ')}`
    );

    const prodData = prodSheet.getRange('A3:K33').getValues();
    const prodMap = {};
    for (const row of prodData) {
      const day = Number(row[0]);
      if (!day) continue;
      prodMap[day] = {
        d15: row[3], e05: row[4], f033: row[5],
        i15b: row[8], j05b: row[9], k033b: row[10],
      };
    }

    const nightDays = {}, pDays = {}, bDays = {}, lDays = {};

    for (let ci = 0; ci < dateRow.length; ci++) {
      const day = Number(dateRow[ci]);
      if (!day) continue;
      for (const sr of staffRows) {
        const val = sr[ci];
        if (val === '야') nightDays[day] = (nightDays[day] || 0) + 1;
        if (val === 'P') pDays[day] = (pDays[day] || 0) + 1;
        if (val === 'B') bDays[day] = (bDays[day] || 0) + 1;
        if (val === 'L') lDays[day] = (lDays[day] || 0) + 1;
      }
    }

    const nightTypeSet = new Set();
    let nightTotalDays = 0, nightTotalPeople = 0;
    for (const day of Object.keys(nightDays).map(Number).sort((a,b) => a-b)) {
      nightTotalDays++;
      nightTotalPeople += nightDays[day];
      const prod = prodMap[day];
      if (prod) {
        if (Number(prod.d15) > 0) nightTypeSet.add('1.5L');
        if (Number(prod.e05) > 0) nightTypeSet.add('0.5L');
        if (Number(prod.f033) > 0) nightTypeSet.add('0.33L');
      }
    }
    const nightTypes = ['1.5L', '0.5L', '0.33L'].filter(t => nightTypeSet.has(t));
    const a23 = nightTotalDays > 0
      ? `○ ${nightTypes.join(', ')} 야간 병제작 (${nightTotalDays}일, ${nightTotalPeople}명)` : '';

    const pTypeSet = new Set();
    let pTotalDays = 0, pTotalPeople = 0;
    for (const day of Object.keys(pDays).map(Number).sort((a,b) => a-b)) {
      pTotalDays++;
      pTotalPeople += pDays[day];
      const prod = prodMap[day];
      if (prod) {
        if (Number(prod.d15) > 0) pTypeSet.add('1.5L');
        if (Number(prod.e05) > 0) pTypeSet.add('0.5L');
        if (Number(prod.f033) > 0) pTypeSet.add('0.33L');
      }
    }
    const pTypes = ['1.5L', '0.5L', '0.33L'].filter(t => pTypeSet.has(t));
    const a24 = pTotalDays > 0
      ? `○ ${pTypes.join(', ')} 제품 생산 연장 (${pTotalDays}일, ${pTotalPeople}명)` : '';

    const bTypeSet = new Set();
    let bTotalDays = 0, bTotalPeople = 0;
    for (const day of Object.keys(bDays).map(Number).sort((a,b) => a-b)) {
      bTotalDays++;
      bTotalPeople += bDays[day];
      const prod = prodMap[day];
      if (prod) {
        if (Number(prod.i15b) > 0) bTypeSet.add('1.5L');
        if (Number(prod.j05b) > 0) bTypeSet.add('0.5L');
        if (Number(prod.k033b) > 0) bTypeSet.add('0.33L');
      }
    }
    const bTypes = ['1.5L', '0.5L', '0.33L'].filter(t => bTypeSet.has(t));
    const a25 = bTotalDays > 0
      ? `○ ${bTypes.join(', ')} 병 생산 연장 (${bTotalDays}일, ${bTotalPeople}명)` : '';

    let lTotalDays = 0, lTotalPeople = 0;
    for (const day of Object.keys(lDays).map(Number).sort((a,b) => a-b)) {
      lTotalDays++;
      lTotalPeople += lDays[day];
    }
    const a26 = lTotalDays > 0
      ? `○ 정비 연장 (${lTotalDays}일, ${lTotalPeople}명)` : '';

    const outSheet = keunTaeSS.getSheetByName('연장근무 발생 보고');
    if (!outSheet) throw new Error('"연장근무 발생 보고" 시트를 찾을 수 없습니다.');

    outSheet.getRange('A23').setValue(a23);
    outSheet.getRange('D16').setValue(nightTotalPeople * 4);
    outSheet.getRange('A24').setValue(a24);
    outSheet.getRange('A25').setValue(a25);
    outSheet.getRange('A26').setValue(a26);

    SpreadsheetApp.getUi().alert('✅ 완료!\n\nA23~A26 입력이 완료되었습니다.');

  } catch (e) {
    SpreadsheetApp.getUi().alert('❌ 오류 발생:\n' + e.message);
  }
}

