function importWorkPlan() {
  const ui = SpreadsheetApp.getUi();
  try {
    const destSS = SpreadsheetApp.getActiveSpreadsheet();

    const statusSheetName = findSheetByPattern(destSS, /^\d+월 근무현황표$/);
    if (!statusSheetName) throw new Error('"X월 근무현황표" 시트를 찾을 수 없습니다.');
    const statusSheet = destSS.getSheetByName(statusSheetName);
    const targetMonth = Number(statusSheet.getRange('Z3').getValue());
    const targetYear  = Number(statusSheet.getRange('X3').getValue());
    validateMonth(targetMonth, statusSheet.getRange('Z3').getValue());
    const lastDay = getLastDayOfMonth(targetYear, targetMonth);

    const { srcNameMap, srcDateMap, srcDataGrid } = loadSourceData(targetMonth);
    const targets = [
      { sheetName: statusSheetName,                              nameStartRow: 8, nameMaxRow: 23, dataStartCol: 3 },
      { sheetName: findSheetByPattern(destSS, /^간식정산$/),     nameStartRow: 8, nameMaxRow: 17, dataStartCol: 3 },
      { sheetName: findSheetByPattern(destSS, /^연장야근정산$/), nameStartRow: 8, nameMaxRow: 23, dataStartCol: 3 },
    ];

    let totalUpdated = 0;
    let totalSkipped = 0;
    const logs = [];

    for (const target of targets) {
      if (!target.sheetName) { logs.push('⚠️ 대상 시트를 찾을 수 없음 — 건너뜀'); continue; }
      const sheet = destSS.getSheetByName(target.sheetName);
      const { updated, skipped, log } = writeToSheet({
        sheet, srcNameMap, srcDateMap, srcDataGrid,
        nameStartRow: target.nameStartRow,
        nameMaxRow:   target.nameMaxRow,
        dataStartCol: target.dataStartCol,
      });
      applyColumnVisibility(sheet, lastDay);
      logs.push(`✅ [${target.sheetName}] ${updated}개 입력` + (skipped > 0 ? ` / ${skipped}명 미매칭` : ''));
      logs.push(...log);
      totalUpdated += updated;
      totalSkipped += skipped;
    }

    ui.alert(
      `📥 ${targetMonth}월 당월 근무계획 가져오기 완료\n\n` +
      logs.join('\n') +
      `\n\n총 ${totalUpdated}개 셀 입력 / ${totalSkipped}명 매칭 실패`
    );

  } catch (e) {
    ui.alert('❌ 오류 발생\n\n' + e.message);
    console.error(e);
  }
}

