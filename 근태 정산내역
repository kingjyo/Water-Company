function processFillOne(range, specialList, fillOne = true) {
  const values = range.getValues();
  const backgrounds = range.getBackgrounds();
  const special = new Set(specialList.map(s => s.trim()));

  for (let r = 0; r < values.length; r++) {
    for (let c = 0; c < values[r].length; c++) {
      const str = (values[r][c] == null || values[r][c] === '') ? '' : String(values[r][c]).trim();
      const bg = backgrounds[r][c] ? backgrounds[r][c].toLowerCase() : '';
      const isYellowGyo = (str === '교' && bg === '#ffff00');

      if (isYellowGyo) {
        values[r][c] = '교';
      } else if (fillOne && (str === '' || !special.has(str))) {
        values[r][c] = 1;
      }
      backgrounds[r][c] = '#ffffff';
    }
  }

  range.setValues(values);
  range.setBackgrounds(backgrounds);
  range.setHorizontalAlignment('center');
  range.setVerticalAlignment('middle');
  SpreadsheetApp.flush();
}

function convertPBLtoYeonAndClear() {
  const destSS = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = SpreadsheetApp.getActiveSheet();
  const { year, month } = resolveYearMonthForActiveSheet(destSS, sheet);
  const lastDay = getLastDayOfMonth(year, month);
  const nightText = processPBLtoYeonAndClear(sheet, lastDay);
  SpreadsheetApp.getUi().alert(
    `완료\n• P, B, L → "연" 변환\n• "연", "야" 외 전부 공란\n• 배경색 하얀색\n` +
    `• AD27: ${nightText}\n(${year}년 ${month}월 기준, ${lastDay}일까지)`
  );
}

function processPBLtoYeonAndClear(sheet, lastDay) {
  const endCol = colIndexToLetter(2 + lastDay);
  const lastRow = getDataLastRow(sheet, 8, 23);
  const dataRange = sheet.getRange(`C8:${endCol}${lastRow}`);
  const values = dataRange.getValues();
  const backgrounds = dataRange.getBackgrounds();
  const pbl = new Set(["P", "B", "L"]);
  const keepers = new Set(["연", "야"]);

  for (let r = 0; r < values.length; r++) {
    for (let c = 0; c < values[r].length; c++) {
      const str = (values[r][c] == null ? '' : String(values[r][c])).trim();
      if (pbl.has(str)) values[r][c] = "연";
    }
  }

  let nightCount = 0;
  for (let r = 0; r < values.length; r++) {
    for (let c = 0; c < values[r].length; c++) {
      const str = (values[r][c] == null ? '' : String(values[r][c])).trim();
      if (str === "야") nightCount++;
      if (str !== '' && !keepers.has(str)) values[r][c] = '';
      backgrounds[r][c] = '#ffffff';
    }
  }

  dataRange.setValues(values);
  dataRange.setBackgrounds(backgrounds);
  dataRange.setHorizontalAlignment('center');
  dataRange.setVerticalAlignment('middle');

  const overtimeSumRow = getAttendSumRow(sheet, 8, 30);
  const nightInputRow = overtimeSumRow + 3;
  const nightText = `(${nightCount}인 × 3식)`;
  sheet.getRange(nightInputRow, 30).setValue(nightText);
  SpreadsheetApp.flush();
  return nightText;
}

function accumulateCumulative() {
  const sheet = SpreadsheetApp.getActiveSheet();
  const { updatedCount, skippedCount } = processAccumulate(sheet);
  SpreadsheetApp.getUi().alert(
    '누계 처리 완료\n\n' +
    `• 업데이트된 셀: ${updatedCount}개\n` +
    `• 건너뜀: ${skippedCount}개\n\n` +
    '형식 예시: =0+4+3'
  );
}

function processAccumulate(sheet) {
  const startRow = 7;
  const sumRow = getAttendSumRow(sheet, startRow, 30);
  const endRow = sumRow - 1;

  const sheetName = sheet.getName();
  const isJanuary = /^1월 근태$/.test(sheetName.trim());

  const columnPairs = [
    { current: "K", cumulative: "L" },
    { current: "M", cumulative: "N" },
    { current: "M", cumulative: "G" },
    { current: "O", cumulative: "P" },
    { current: "O", cumulative: "H" },
  ];

  let skippedCount = 0;
  let updatedCount = 0;

  for (const pair of columnPairs) {
    for (let row = startRow; row <= endRow; row++) {
      const currentCell = sheet.getRange(`${pair.current}${row}`);
      const cumulCell = sheet.getRange(`${pair.cumulative}${row}`);
      const currentVal = currentCell.getValue();
      const currentStr = (currentVal == null || currentVal === '') ? '' : String(currentVal).trim();

      if (currentStr === '') { skippedCount++; continue; }
      const addValue = (currentStr === '-') ? 0 : Number(currentStr);
      if (isNaN(addValue)) { skippedCount++; continue; }

      if (isJanuary) {
        cumulCell.setValue(addValue);
        updatedCount++;
        continue;
      }

      const existingFormula = cumulCell.getFormula();
      const existingValue = cumulCell.getValue();
      let baseStr;

      if (existingFormula && existingFormula.startsWith('=')) {
        baseStr = existingFormula.slice(1);
      } else {
        const existingNum = (existingValue == null || existingValue === '') ? 0 : Number(existingValue);
        baseStr = isNaN(existingNum) ? '0' : String(existingNum);
      }

      cumulCell.setFormula(`=${baseStr}+${addValue}`);
      updatedCount++;
    }
  }

  SpreadsheetApp.flush();
  return { updatedCount, skippedCount };
}

