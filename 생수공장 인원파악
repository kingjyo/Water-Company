    { lbl:"조출 (품질)", ppl:jo,    note:jo.length    ? cipNote(prodData)             : "—", bg:BG.SHFT_R },
    { lbl:"연장 (품질)", ppl:yeon,  note:yeon.length  ? cipNote(prodData)             : "—", bg:BG.WHITE  },
    { lbl:"연장 (현장)", ppl:ext,   note:ext.length   ? shiftNote(workData, prodData) : "—", bg:BG.SHFT_R },
    { lbl:"야간 (현장)", ppl:night, note:night.length ? nightNote(prodData)           : "—", bg:BG.WHITE  }
  ].forEach((s, i) => {
    const r = 8 + i;
    sc(ws, r, 6, s.lbl, BG.SHFT_H, FG.WHITE, true);
    dataCell(ws, r, 7, s.ppl.length ? s.ppl.join(", ") : "—", s.bg);
    dataCell(ws, r, 8, s.ppl.length || "", s.bg, true, 12);
    dataCell(ws, r, 9, s.note, s.bg);
  });

  // ── 비근무 K~N ───────────────────────────────────────────
  groups.forEach((g, i) => {
    const r  = 8 + i;
    const bg = (i % 2 === 0) ? BG.OFF_R : BG.WHITE;
    sc(ws, r, 11, g + "그룹", BG.OFF_H, FG.WHITE, true);
    const names  = absent[g].map(n => n).join(", ");
    const reason = absent[g].map(n => n + " " + (OFF_REASON[workData[n]] || workData[n])).join(", ");
    dataCell(ws, r, 12, names  || "—", bg);
    dataCell(ws, r, 13, absent[g].length || "", bg, true, 12);
    dataCell(ws, r, 14, reason || "—", bg);
  });
  sc(ws, 11, 11, "—", BG.OFF_R, FG.DARK, false);
  [12, 13, 14].forEach(c => ws.getRange(11, c).setBackground(BG.WHITE));

  // ── 12:20 식사 인원 (삼익 포함) P1:R2 ───────────────────────
  // shiftCnt, hasTan 계산 완료 후 실행
  const samCount = shiftCnt + (hasTan ? 2 : 0);
  const samBG    = "#FFF0E0";
  const samHDR   = "#F4A020";

  // 행1: 헤더
  const samHeaderRange = ws.getRange(1, SAM_START, 1, SAM_COLS);
  samHeaderRange.merge();
  samHeaderRange.setValue("🍱  12:20 식사 (삼익 포함)")
    .setBackground(samHDR).setFontColor("#FFFFFF")
    .setFontWeight("bold").setFontSize(10)
    .setHorizontalAlignment("center").setVerticalAlignment("middle")
    .setFontFamily("맑은 고딕");

  // 행2: 인원 값
  const samContentRange = ws.getRange(2, SAM_START, 1, SAM_COLS);
  samContentRange.merge();
  if (samCount > 0) {
    const samText = samCount + "명"
      + (hasTan ? "  (자사 " + shiftCnt + " + 삼익 2)" : "  (자사 " + shiftCnt + "명)");
    samContentRange.setValue(samText)
      .setBackground(samBG).setFontColor("#1A1A1A")
      .setFontWeight("bold").setFontSize(10)
      .setHorizontalAlignment("center").setVerticalAlignment("middle")
      .setFontFamily("맑은 고딕").setWrap(true);
  } else {
    samContentRange.setValue("—")
      .setBackground(samBG).setFontColor("#888888")
      .setFontWeight("normal").setFontSize(10)
      .setHorizontalAlignment("center").setVerticalAlignment("middle")
      .setFontFamily("맑은 고딕");
  }

  // 행3: 흰색
  ws.getRange(3, SAM_START, 1, SAM_COLS)
    .setBackground(BG.WHITE)
    .setBorder(false, false, false, false, false, false);

  // ── 식수 인원 P~S ─────────────────────────────────────────
  // ★ 11:20 식사: 12:20 식사와 완전히 동일한 로직
  //   - BTL 또는 CAP 생산 시: 2명
  //   - 탄산(0.19L 캔) 생산 시: 1명
  //   - 둘 다이면 합산
  let meal1120Count = 0;
  const meal1120Reasons = [];
  if (hasBTL || hasCAP) {
    meal1120Count += 2;
    const btlN = prodData.filter(p => p.type === "BTL").map(p => p.name.replace(" BTL", ""));
    const parts1120 = [];
    if (btlN.length) parts1120.push(btlN.join(", ") + " BTL");
    if (hasCAP) parts1120.push("CAP");
    meal1120Reasons.push(parts1120.join("/") + " 생산");
  }
  if (hasTan) {
    meal1120Count += 1;
    meal1120Reasons.push("0.19L 캔 생산");
  }
  const meal1120Reason = meal1120Count > 0 ? meal1120Reasons.join(", ") : "—";

  // ★ 12:00 식사: 총출근 - (11:20 교대 + 12:20 교대)
  const totalShiftMeal = meal1120Count + shiftCnt;
  const meal1200actual = totalPresent - totalShiftMeal;
  const meal1200reason = totalShiftMeal > 0
    ? "교대 " + totalShiftMeal + "명 제외"
    : "전원 12:00 식사";

  // 출근자가 0명이면 식수 행 전체 "—" 처리
  const noWorkers = totalPresent === 0;

  [
    {
      lbl: "총 출근인원",
      val: totalPresent,
      reason: noWorkers ? "—" : "전체 출근자",
      note: "—",
      bg: BG.MEAL_R
    },
    {
      lbl: "11:20 식사",
      val: (!noWorkers && meal1120Count > 0) ? meal1120Count : "—",
      reason: (!noWorkers && meal1120Count > 0) ? meal1120Reason : "—",
      note: (!noWorkers && meal1120Count > 0) ? "11:20 교대 식사" : "—",
      bg: BG.WHITE
    },
    {
      lbl: "12:00 식사",
      val: noWorkers ? "—" : (totalShiftMeal > 0 ? meal1200actual : totalPresent),
      reason: noWorkers ? "—" : meal1200reason,
      note: "—",
      bg: BG.MEAL_R
    },
    {
      lbl: "12:20 식사",
      val: (!noWorkers && shiftCnt > 0) ? shiftCnt : "—",
      reason: (!noWorkers && shiftCnt > 0) ? shiftReasons.join(", ") : "—",
      note: (!noWorkers && shiftCnt > 0) ? "12:20 교대 식사" : "—",
      bg: BG.WHITE
    }
  ].forEach((m, i) => {
    const r = 8 + i;
    sc(ws, r, 16, m.lbl,    BG.MEAL_H, FG.DARK, true);
    dataCell(ws, r, 17, m.val,    m.bg, true, 12);
    dataCell(ws, r, 18, m.reason, m.bg);
    dataCell(ws, r, 19, m.note,   m.bg);
  });

  // ════════════════════════════════════════════════════════
  // 행12: 합계
  // ════════════════════════════════════════════════════════
  const totalWork  = present.생산.length + present.품질.length + present.현장.length;
  const totalShift = jo.length + yeon.length + ext.length + night.length;
  const totalOff   = absent.생산.length + absent.품질.length + absent.현장.length;

  sc(ws, 12, 1, "합 계", BG.SUM_H, FG.WHITE, true);
  ws.getRange(12, 2, 1, 2).merge();
  dataCell(ws, 12, 2, "출근: " + totalWork + "명", BG.SUM_H, true, 10, FG.WHITE);
  dataCell(ws, 12, 4, totalWork, BG.SUM_H, true, 12, FG.WHITE);
  ws.getRange(12, 5).setBackground(BG.GRAY);
  sc(ws, 12, 6, "합 계", BG.SUM_H, FG.WHITE, true);
  dataCell(ws, 12, 7, "교대/연장/야간: " + totalShift + "명", BG.SUM_H, true, 10, FG.WHITE);
  dataCell(ws, 12, 8, totalShift, BG.SUM_H, true, 12, FG.WHITE);
  ws.getRange(12, 9).setBackground(BG.SUM_H);
  ws.getRange(12, 10).setBackground(BG.GRAY);
  sc(ws, 12, 11, "합 계", BG.SUM_H, FG.WHITE, true);
  dataCell(ws, 12, 12, "비근무: " + totalOff + "명", BG.SUM_H, true, 10, FG.WHITE);
  dataCell(ws, 12, 13, totalOff, BG.SUM_H, true, 12, FG.WHITE);
  ws.getRange(12, 14).setBackground(BG.SUM_H);
  ws.getRange(12, 15).setBackground(BG.GRAY);
  mc(ws, "P12:S12",
     "총 인원: " + (totalWork + totalOff) + "명  (출근 " + totalWork + " / 비근무 " + totalOff + ")",
     BG.SUM_H, FG.WHITE, true);

  // ════════════════════════════════════════════════════════
  // 구분선 및 테두리
  // ════════════════════════════════════════════════════════
  // 시트 격자선 숨김 (표 범위 밖 격자 제거)
  ws.setHiddenGridlines(true);

  // 구분선 열: 행4는 E만 회색, J/O는 흰색 (생산계획 영역 밖이므로)
  ws.getRange("E4:E12").setBackground(BG.GRAY);
  ws.getRange("J4").setBackground(BG.WHITE);
  ws.getRange("O4").setBackground(BG.WHITE);
  ws.getRange("J5:J12").setBackground(BG.GRAY);
  ws.getRange("O5:O12").setBackground(BG.GRAY);

  // 본표(행5~12) 전체 테두리
  ws.getRange("A5:S12").setBorder(
    true, true, true, true, true, true,
    "#AAAAAA", SpreadsheetApp.BorderStyle.SOLID
  );
  // 생산계획(행1~4) 테두리
  const prodRangeA1 = "A1:" + colLetter(titleEndCol) + "4";
  ws.getRange(prodRangeA1).setBorder(
    true, true, true, true, true, true,
    "#AAAAAA", SpreadsheetApp.BorderStyle.SOLID
  );
  // LC 섹션(행1~2만) 테두리
  ws.getRange(1, LC_START, 2, LC_COLS).setBorder(
    true, true, true, true, true, true,
    "#AAAAAA", SpreadsheetApp.BorderStyle.SOLID
  );
  // 굵은 외곽선
  ["A1:" + colLetter(titleEndCol) + "3",
   "A5:S5","A6:D12","F6:I12","K6:N12","P6:S12"].forEach(r => {
    ws.getRange(r).setBorder(
      true, true, true, true, null, null,
      "#555555", SpreadsheetApp.BorderStyle.SOLID_MEDIUM
    );
  });
  ws.getRange("A1:" + colLetter(titleEndCol) + "4").setBorder(
    true, true, true, true, null, null,
    "#555555", SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );
  // LC 섹션 외곽 굵은 테두리 (행1~2만)
  ws.getRange(1, LC_START, 2, LC_COLS).setBorder(
    true, true, true, true, null, null,
    "#7030A0", SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );
  // SAM 섹션(행1~2) 테두리
  ws.getRange(1, SAM_START, 2, SAM_COLS).setBorder(
    true, true, true, true, true, true,
    "#AAAAAA", SpreadsheetApp.BorderStyle.SOLID
  );
  ws.getRange(1, SAM_START, 2, SAM_COLS).setBorder(
    true, true, true, true, null, null,
    "#F4A020", SpreadsheetApp.BorderStyle.SOLID_MEDIUM
  );
}

