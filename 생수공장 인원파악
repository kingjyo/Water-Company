// ★ CIP 표기에서 "캔" 제거: "0.19L 캔" → "0.19L"
function cipNote(prodData) {
  const items = prodData
    .filter(p => p.type === "제품" || p.type === "탄산")
    .map(p => p.name.replace(" 캔", ""));  // "캔" 제거
  return items.length ? items.join(", ") + " CIP" : "해당 없음";
}

function shiftNote(workData, prodData) {
  const codes   = Object.values(workData);
  const reasons = [];
  if (codes.includes("P")) {
    // 18.9L, 0.12L는 연장 사유 아님 (오전/17:30까지만 생산)
    const EXCLUDE = ["18.9L", "0.12L"];
    const items = prodData
      .filter(p => p.type === "제품" && !EXCLUDE.includes(p.name))
      .map(p => p.name);
    if (items.length) reasons.push(items.join(", ") + " 제품 생산");
  }
  if (codes.includes("B")) {
    const items = prodData.filter(p => p.type === "BTL").map(p => p.name.replace(" BTL", ""));
    if (items.length) reasons.push(items.join(", ") + " BTL 생산");
  }
  if (codes.includes("L")) reasons.push("L/C 및 정비 연장");
  return reasons.length ? reasons.join(", ") : "해당 없음";
}

// ★ nightNote: BTL 이름에서 " BTL" 중복 방지
function nightNote(prodData) {
  const btlNames = prodData.filter(p => p.type === "BTL").map(p => p.name.replace(" BTL", ""));
  const cap = prodData.filter(p => p.type === "CAP");
  if (!btlNames.length && !cap.length) return "해당 없음";
  const parts = [];
  if (btlNames.length) parts.push(btlNames.join(", ") + " BTL");
  if (cap.length)      parts.push("CAP");
  return parts.join("/") + " 생산";
}

// ============================================================
//  셀 서식 헬퍼
// ============================================================
function sc(ws, row, col, value, bg, fg, bold, size) {
  const c = ws.getRange(row, col);
  c.setValue(value);
  if (bg)    c.setBackground(bg);
  if (fg)    c.setFontColor(fg);
  c.setFontWeight(bold ? "bold" : "normal");
  if (size)  c.setFontSize(size);
  c.setHorizontalAlignment("center");
  c.setVerticalAlignment("middle");
  c.setFontFamily("맑은 고딕");
  c.setWrap(true);
}

function mc(ws, a1, value, bg, fg, bold, size) {
  const r = ws.getRange(a1);
  r.merge();
  r.setValue(value);
  if (bg)    r.setBackground(bg);
  if (fg)    r.setFontColor(fg);
  r.setFontWeight(bold ? "bold" : "normal");
  if (size)  r.setFontSize(size);
  r.setHorizontalAlignment("center");
  r.setVerticalAlignment("middle");
  r.setFontFamily("맑은 고딕");
  r.setWrap(true);
}

function dataCell(ws, row, col, value, bg, bold, size, fg) {
  const c = ws.getRange(row, col);
  if (value !== undefined && value !== null) c.setValue(value);
  if (bg)    c.setBackground(bg);
  if (fg)    c.setFontColor(fg);
  c.setFontWeight(bold ? "bold" : "normal");
  if (size)  c.setFontSize(size);
  c.setHorizontalAlignment("center");
  c.setVerticalAlignment("middle");
  c.setFontFamily("맑은 고딕");
  c.setWrap(true);
}

function colLetter(n) {
  let s = "";
  while (n > 0) { s = String.fromCharCode(64 + (n % 26 || 26)) + s; n = Math.floor((n - 1) / 26); }
  return s;
}

function showAlert(msg) {
  try { SpreadsheetApp.getUi().alert(msg); } catch(e) { Logger.log(msg); }
}

