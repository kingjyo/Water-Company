/**
 * 근무계획 스프레드시트에서 해당 월의 근태 데이터를 가져와
 * 즉시 코드 변환까지 수행합니다.
 *
 *  처리 순서:
 *  1. B1 셀 파싱 → 연도/월/마지막일 확정
 *  2. 근무계획 스프레드시트에서 해당 월 데이터 로드
 *  3. 이름 매칭 (B열 이름 ↔ 근무계획 이름)
 *  4. 날짜별 코드 변환 후 C열~lastDay열까지 일괄 입력
 *  5. 가운데 정렬 적용
 */
function importAndConvert() {
  const ui    = SpreadsheetApp.getUi();
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();

  try {
    // ── STEP 1. 헤더에서 연/월/마지막일 파싱 ──────────────────────────
    const { year, month } = parseHeaderMonth(sheet);
    const lastDay = getLastDayOfMonth(year, month);

    // ── STEP 2. 근무계획 로드 ──────────────────────────────────────────
    const { srcWorkerCount, dateMap: srcDateMap, dataGrid: srcDataGrid }
      = loadWorkPlanData(month);

    if (srcWorkerCount === 0) {
      throw new Error(`근무계획 "${month}월" 시트에서 작업자 데이터를 찾을 수 없습니다.`);
    }

    // ── STEP 3. 목적지 작업자 행 목록 읽기 ────────────────────────────
    // A열(col 1)에 사번이 있는 행을 수집 (3행부터)
    // 근태코드 변환 시트에는 이름 없이 사번만 있으므로 행 순서로 매칭
    const lastRow = sheet.getLastRow();
    if (lastRow < 3) throw new Error('3행부터 데이터가 존재해야 합니다.');

    const aColValues = sheet.getRange(3, 1, lastRow - 2, 1).getValues();
    const destRows = [];
    for (let i = 0; i < aColValues.length; i++) {
      const id = String(aColValues[i][0] ?? '').trim();
      if (id === '') continue; // 빈 행은 건너뜀
      destRows.push(3 + i);   // 실제 시트 행 번호
    }
    if (destRows.length === 0) {
      throw new Error('A열에서 사번을 찾을 수 없습니다.\n3행부터 A열에 사번이 입력되어 있는지 확인하세요.');
    }

    // ── STEP 4. 데이터 영역 초기화 ────────────────────────────────────
    const lastWorkerRow = destRows[destRows.length - 1];
    // B열(col 2) = 1일, C열(col 3) = 2일, … → 데이터 시작: col 2
    sheet.getRange(3, 2, lastWorkerRow - 2, lastDay).clearContent();

    // ── STEP 5. 행 순서대로 1:1 매핑 → 코드 변환 후 입력 ─────────────
    // 근무계획 0번째 작업자 → 목적지 1번째 사번 행
    // 근무계획 1번째 작업자 → 목적지 2번째 사번 행  … 순서 대응
    const processCount = Math.min(destRows.length, srcWorkerCount);

    for (let idx = 0; idx < processCount; idx++) {
      const destRow   = destRows[idx];   // 목적지 시트 행 번호
      const srcRowIdx = idx;             // 근무계획 그리드 행 인덱스 (0-based)

      // 1일~lastDay일 코드를 배열로 구성
      const rowData = [];
      for (let day = 1; day <= lastDay; day++) {
        let converted = DEFAULT_VALUE;
        if (day in srcDateMap) {
          const raw = String(srcDataGrid[srcRowIdx][srcDateMap[day]] ?? '').trim();
          if (raw !== '') {
            converted = REPLACEMENT_MAP.hasOwnProperty(raw)
              ? REPLACEMENT_MAP[raw]
              : DEFAULT_VALUE;
          }
        }
        rowData.push(converted);
      }

      // B열(1일)부터 lastDay열까지 한 행 일괄 입력
      sheet.getRange(destRow, 2, 1, lastDay).setValues([rowData]);
    }

    // ── STEP 6. 가운데 정렬 적용 ─────────────────────────────────────
    sheet.getRange(3, 2, lastWorkerRow - 2, lastDay).setHorizontalAlignment('center');
    SpreadsheetApp.flush();

    // ── STEP 7. 완료 알림 ─────────────────────────────────────────────
    const lastDayCol = colIndexToLetter(1 + lastDay);  // B=col2=1일, day N → col(1+N)
    const lastColStr = `${lastDayCol}${lastWorkerRow}`;

    const countMsg = destRows.length !== srcWorkerCount
      ? `\n• ⚠️ 인원 수 불일치 — 목적지: ${destRows.length}명 / 근무계획: ${srcWorkerCount}명\n  (적은 쪽 기준 ${processCount}명 처리)`
      : `\n• 전체 ${processCount}명 처리 완료`;

    ui.alert(
      `📥 ${year}년 ${month}월 근무계획 가져오기 + 코드 변환 완료!\n\n` +
      `• 처리 기간: ${month}월 1일 ~ ${lastDay}일 (${lastDay}일간)\n` +
      `• 처리 범위: B3:${lastColStr}` +
      countMsg
    );

  } catch (e) {
    ui.alert('❌ 오류 발생\n\n' + e.message);
    console.error(e);
  }
}

