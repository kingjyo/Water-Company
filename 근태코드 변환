// 코드 변환만 실행 (기존 기능 — 월 기반 열 범위 적용)
// ─────────────────────────────────────────────────────────────────────────────

/**
 * 현재 시트에 이미 입력된 근태 문자(연/야/공 등)를 코드로 변환합니다.
 * B1 셀의 연/월을 읽어 해당 월의 마지막 날까지만 변환합니다.
 *
 *  변환 조건:
 *  - A열에 사번이 있는 행만 변환 대상
 *  - 변환 규칙에 없는 값(빈 칸 포함) → DEFAULT_VALUE("I61")
 */
function replaceShiftCodes() {
  const ui    = SpreadsheetApp.getUi();
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();

  try {
    const { year, month } = parseHeaderMonth(sheet);
    const lastDay = getLastDayOfMonth(year, month);

    const lastRow = sheet.getLastRow();
    const numRows = lastRow - 2;
    if (numRows <= 0) {
      ui.alert('3행부터 데이터가 존재해야 합니다.');
      return;
    }

    // A열: 사번 (3행부터)
    const idValues = sheet.getRange(3, 1, numRows, 1).getValues();

    // B열~lastDay열: 근태 데이터 (B=1일, C=2일, … → col 2 = day 1)
    const dataRange  = sheet.getRange(3, 2, numRows, lastDay);
    const dataValues = dataRange.getValues();

    const newValues = dataValues.map((row, i) => {
      const empId = String(idValues[i][0] ?? '').trim();
      if (!empId) return row;   // 사번 없는 행은 변환하지 않음
      return row.map(cell => {
        const key = String(cell ?? '').trim();
        if (key === '') return DEFAULT_VALUE;
        return REPLACEMENT_MAP.hasOwnProperty(key) ? REPLACEMENT_MAP[key] : DEFAULT_VALUE;
      });
    });

    dataRange.setValues(newValues);
    dataRange.setHorizontalAlignment('center');
    SpreadsheetApp.flush();

    const lastDayCol = colIndexToLetter(1 + lastDay);  // B=col2=1일, day N → col(1+N)
    ui.alert(
      `근태 코드 변환이 완료되었습니다!\n\n` +
      `• ${year}년 ${month}월 기준 (${lastDay}일까지)\n` +
      `• 처리 범위: B3:${lastDayCol}${lastRow}\n` +
      `• 변환 규칙 적용 + 가운데 정렬 완료`
    );

  } catch (e) {
    ui.alert('❌ 오류 발생\n\n' + e.message);
    console.error(e);
  }
}