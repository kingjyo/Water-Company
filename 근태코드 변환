/** 근무계획 스프레드시트 ID */
const SOURCE_SS_ID = '12yP7AxfC_27B6LhSEJ4lFH5ZYnymyQIlcbPXXhpDUBY';

/** 근태 코드 변환 규칙 */
const REPLACEMENT_MAP = {
  "년": "V01",
  "무": "G03",
  "휴": "G01",
  "조": "H61",
  "연": "L11",
  "야": "R86",
  "공": "G02",
  "퇴": "K01",
  "출": "T01",
  "예": "E04",
  "민": "E05",
  "상": "T08",
};

/** 변환 규칙에 없는 코드에 적용할 기본값 */
const DEFAULT_VALUE = "I61";

