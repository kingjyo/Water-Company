/**
 * B1 병합셀의 "2026년 4월" 텍스트에서 연도와 월을 파싱합니다.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @returns {{ year: number, month: number }}
 */
function parseHeaderMonth(sheet) {
  const raw = String(sheet.getRange('B1').getValue()).trim();
  const m = raw.match(/(\d{4})년\s*(\d{1,2})월/);
  if (!m) {
    throw new Error(
      `B1 셀에서 연/월을 읽을 수 없습니다: "${raw}"\n"2026년 4월" 형식으로 입력되어 있는지 확인하세요.`
    );
  }
  return { year: Number(m[1]), month: Number(m[2]) };
}

/**
 * year년 month월의 마지막 날짜를 반환합니다. (윤년 자동 처리)
 * @param {number} year
 * @param {number} month
 * @returns {number}
 */
function getLastDayOfMonth(year, month) {
  return new Date(year, month, 0).getDate();
}

/**
 * 열 번호(1부터 시작)를 엑셀 알파벳으로 변환합니다.
 * 예) 3 → "C", 32 → "AF", 33 → "AG"
 * @param {number} n
 * @returns {string}
 */
function colIndexToLetter(n) {
  let s = '';
  while (n > 0) {
    s = String.fromCharCode(65 + (n - 1) % 26) + s;
    n = Math.floor((n - 1) / 26);
  }
  return s;
}

// ─────────────────────────────────────────────────────────────────────────────
// 근무계획 데이터 로드
// ─────────────────────────────────────────────────────────────────────────────

/**
 * 근무계획 스프레드시트의 지정 월 시트에서 데이터를 로드합니다.
 *
 *  핵심 로직:
 *  - A열 + C열을 5행부터 스캔하여 "계" 또는 "합계" 텍스트가 있는 행을 탐지
 *  - 탐지된 행의 직전 행까지만 데이터 범위로 사용 (인원 유동 대응)
 *
 * @param {number} month  가져올 월 (1~12)
 * @returns {{
 *   srcWorkerCount: number,             // 근무계획상 작업자 수
 *   dateMap:  Object.<number, number>,  // 날짜(1~31) → 열 인덱스(0-based, G열 기준)
 *   dataGrid: Array.<Array.<*>>         // [행][열] 근태 값 2D 배열 (행=작업자 순서)
 * }}
 */
function loadWorkPlanData(month) {
  const sourceSS = SpreadsheetApp.openById(SOURCE_SS_ID);
  const sourceSheet = sourceSS.getSheetByName(`${month}월`);
  if (!sourceSheet) {
    throw new Error(
      `근무계획 스프레드시트에서 "${month}월" 시트를 찾을 수 없습니다.\n` +
      `시트 목록: ${sourceSS.getSheets().map(s => s.getName()).join(', ')}`
    );
  }

  // ── 날짜 헤더 행 (G3:AK3) ─────────────────────────────────────────────
  const DATE_START_COL = 7;   // G열
  const DATE_COL_COUNT = 31;  // G~AK (31열)
  const dateRow = sourceSheet.getRange(3, DATE_START_COL, 1, DATE_COL_COUNT).getValues()[0];

  // ── "계" 행 동적 탐지 ─────────────────────────────────────────────────
  // A~C는 병합셀이므로 A열과 C열 모두 확인
  const SCAN_START = 5;
  const SCAN_MAX   = 35;
  const scanCount  = SCAN_MAX - SCAN_START + 1;

  const colA = sourceSheet.getRange(SCAN_START, 1, scanCount, 1).getValues();
  const colC = sourceSheet.getRange(SCAN_START, 3, scanCount, 1).getValues();

  let keiRelIdx = -1;
  for (let i = 0; i < scanCount; i++) {
    const vA = String(colA[i][0] ?? '').replace(/\s/g, '');
    const vC = String(colC[i][0] ?? '').replace(/\s/g, '');
    if (vA === '계' || vA === '합계' || vC === '계' || vC === '합계') {
      keiRelIdx = i;
      break;
    }
  }

  // "계" 를 못 찾으면 19행까지를 기본값으로 사용
  const dataEndRow   = keiRelIdx >= 0 ? SCAN_START + keiRelIdx - 1 : 19;
  const dataRowCount = dataEndRow - SCAN_START + 1;

  if (dataRowCount <= 0) {
    throw new Error(
      `근무계획 데이터 행 범위 오류\n` +
      `"계" 행 탐지 위치: ${keiRelIdx >= 0 ? SCAN_START + keiRelIdx : '미발견'}`
    );
  }

  // ── 근태 데이터 그리드 가져오기 (행 순서 그대로 사용) ────────────────
  const dataGrid = sourceSheet.getRange(SCAN_START, DATE_START_COL, dataRowCount, DATE_COL_COUNT).getValues();

  // dateMap 구성: 날짜 숫자(1~31) → 열 인덱스(0-based, G열 기준)
  const dateMap = {};
  for (let c = 0; c < dateRow.length; c++) {
    const d = Number(dateRow[c]);
    if (!isNaN(d) && d >= 1 && d <= 31) dateMap[d] = c;
  }

  return { srcWorkerCount: dataRowCount, dateMap, dataGrid };
}

