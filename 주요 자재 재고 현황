/**
 * =====================================================================
 * 생수공장 주요 자재 재고 현황 자동화 GAS
 * =====================================================================
 *
 * [동작 방식]
 * 1. 어제 날짜 시트("X월 Y-1일")를 복사 → 오늘 날짜 시트("X월 Y일") 생성
 *    (이미 존재하면 생성 생략, 값만 업데이트)
 * 2. 각 생산일지의 어제(MMDD) 시트에서 마감 재고를 읽어 F4:F22 에 입력
 * 3. B2 에 "yy.m.d 기준" 형식의 오늘 날짜 입력
 *
 * [소스 스프레드시트]
 * 1. 제품 생산일지    — 1WymbNXGMa8EqZmOmm6l2BPbcQeXlvK_pIfzveYNbyg0
 * 2. 반제품 생산일지  — 1VCLbzaVfMGuu5WPAuaSumpLWZKPmnfkygpyPqzAKoV4
 * 3. 탄산음료 생산일지 — 1V2CNYoRY8AaQAcTtiSfHLZKNNI2_Ud9no2qpE5ptYHs
 */

// =====================================================================
// 메뉴
// =====================================================================

function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('재고현황')
    .addItem('📦 현재고 불러오기', 'updateInventory')
    .addSeparator()
    .addItem('도움말', 'showInventoryHelp')
    .addToUi();
}

// =====================================================================
// 소스 스프레드시트 ID 상수
// =====================================================================

const SS_ID_PROD = '1WymbNXGMa8EqZmOmm6l2BPbcQeXlvK_pIfzveYNbyg0'; // 제품 생산일지
const SS_ID_SEMI = '1VCLbzaVfMGuu5WPAuaSumpLWZKPmnfkygpyPqzAKoV4'; // 반제품 생산일지
const SS_ID_CARB = '1V2CNYoRY8AaQAcTtiSfHLZKNNI2_Ud9no2qpE5ptYHs'; // 탄산음료 생산일지

// =====================================================================
// 📦 현재고 불러오기 (메인 함수)
// =====================================================================

function updateInventory() {
  const ui = SpreadsheetApp.getUi();
  const logs = [];

  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();

    // ── 날짜 계산 ────────────────────────────────────────────────────
    const today     = new Date();
    const yesterday = new Date(today);
    yesterday.setDate(today.getDate() - 1);

    // 소스 시트명 (MMDD): 각 생산일지의 어제 시트
    const srcMM = String(yesterday.getMonth() + 1).padStart(2, '0');
    const srcDD = String(yesterday.getDate()).padStart(2, '0');
    const srcSheetName = srcMM + srcDD; // 예: "0408"

    // 현재 스프레드시트 시트명: "X월 Y일"
    const todaySheetName     = `${today.getMonth() + 1}월 ${today.getDate()}일`;
    const yesterdaySheetName = `${yesterday.getMonth() + 1}월 ${yesterday.getDate()}일`;

    // B2 날짜 라벨
    const yy = String(today.getFullYear()).slice(2);
    const m  = String(today.getMonth() + 1);
    const d  = String(today.getDate());
    const dateLabel = `${yy}.${m}.${d} 기준`;

    // ── 오늘 시트 생성 또는 기존 시트 사용 ───────────────────────────
    let todaySheet = ss.getSheetByName(todaySheetName);

    if (todaySheet) {
      // 이미 존재하면 생성 생략
      logs.push(`ℹ️ "${todaySheetName}" 시트 이미 존재 → 값만 업데이트`);
    } else {
      // 어제 시트를 양식(템플릿)으로 복사
      let templateSheet = ss.getSheetByName(yesterdaySheetName);

      if (!templateSheet) {
        // 어제 시트가 없으면 스프레드시트의 마지막 시트를 사용
        const allSheets = ss.getSheets();
        templateSheet = allSheets[allSheets.length - 1];
        logs.push(` ⚠️ "${yesterdaySheetName}" 시트 없음 → "${templateSheet.getName()}" 양식 기준으로 복사`);
      } else {
        logs.push(` 📋 "${yesterdaySheetName}" 시트 양식 복사`);
      }

      todaySheet = templateSheet.copyTo(ss);
      todaySheet.setName(todaySheetName);

      // 어제 시트 바로 앞에 배치 (최신 날짜가 앞으로 오도록)
      ss.setActiveSheet(todaySheet);
      ss.moveActiveSheet(templateSheet.getIndex());

      logs.push(` ✅ "${todaySheetName}" 시트 생성 완료`);
    }

    // ── Source 1: 제품 생산일지 ──────────────────────────────────────
    logs.push('');
    logs.push('[ Source 1 ] 제품 생산일지');
    const { sheet: prodSheet, sheetName: prodDate } =
      findMostRecentSheet(SpreadsheetApp.openById(SS_ID_PROD), '제품 생산일지');
    // ※ GLUE: H39:H40 병합 셀 → 상단 H39 로 읽음
    const prodMap = {
      F5:  prodSheet.getRange('H41').getValue(), // PET SHEET
      F6:  prodSheet.getRange('H42').getValue(), // LID KE
      F7:  prodSheet.getRange('H44').getValue(), // LID OAL
      F8:  prodSheet.getRange('H24').getValue(), // 18.9L CAP
      F9:  prodSheet.getRange('H29').getValue(), // 18.9L CAP SEAL
      F10: prodSheet.getRange('H39').getValue(), // GLUE (병합셀 상단)
      F13: prodSheet.getRange('H32').getValue(), // 1.5L(황) 박스
      F14: prodSheet.getRange('H33').getValue(), // 1.5L(백) 박스
      F15: prodSheet.getRange('H34').getValue(), // 0.5L(황) 박스
      F16: prodSheet.getRange('H35').getValue(), // 0.5L(백) 박스
      F17: prodSheet.getRange('H36').getValue(), // 0.33L(황) 박스
      F18: prodSheet.getRange('H37').getValue(), // 0.33L(백) 박스
      F19: prodSheet.getRange('H38').getValue(), // 0.12L 박스
    };
    logs.push(` ✅ [${prodDate}] 시트 사용 → 13개 항목 읽기 완료`);

    // ── Source 2: 반제품 생산일지 ────────────────────────────────────
    logs.push('[ Source 2 ] 반제품 생산일지');
    const { sheet: semiSheet, sheetName: semiDate } =
      findMostRecentSheet(SpreadsheetApp.openById(SS_ID_SEMI), '반제품 생산일지');
    const semiMap = {
      F4:  semiSheet.getRange('I16').getValue(), // PET RESIN
      F11: semiSheet.getRange('I17').getValue(), // HDPE
      F12: semiSheet.getRange('I18').getValue(), // AA 소거제
    };
    logs.push(` ✅ [${semiDate}] 시트 사용 → 3개 항목 읽기 완료`);

    // ── Source 3: 탄산음료 생산일지 ──────────────────────────────────
    logs.push('[ Source 3 ] 탄산음료 생산일지');
    const { sheet: carbSheet, sheetName: carbDate } =
      findMostRecentSheet(SpreadsheetApp.openById(SS_ID_CARB), '탄산음료 생산일지');
    const carbMap = {
      F20: carbSheet.getRange('H20').getValue(), // 0.19L 하프트레이
      F21: carbSheet.getRange('H17').getValue(), // 0.19L CAN
      F22: carbSheet.getRange('H18').getValue(), // 0.19L END
    };
    logs.push(` ✅ [${carbDate}] 시트 사용 → 3개 항목 읽기 완료`);

    // ── 오늘 시트에 값 입력 ───────────────────────────────────────────
    // B2: 날짜 라벨
    todaySheet.getRange('B2').setValue(dateLabel);

    // F4:F22 전체 입력
    const allMap = { ...prodMap, ...semiMap, ...carbMap };
    for (const [cell, value] of Object.entries(allMap)) {
      todaySheet.getRange(cell).setValue(value == null ? '' : value);
    }

    SpreadsheetApp.flush();

    ui.alert(
      `📦 현재고 불러오기 완료\n\n` +
      `• 오늘 시트: "${todaySheetName}"\n` +
      `• B2: ${dateLabel}\n` +
      `• F4:F22: 19개 항목 입력 완료\n\n` +
      `--- 진행 로그 ---\n` +
      logs.join('\n')
    );

  } catch (e) {
    ui.alert('❌ 오류 발생\n\n' + e.message + '\n\n--- 진행 로그 ---\n' + logs.join('\n'));
    console.error(e);
  }
}

