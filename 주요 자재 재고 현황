/**
 * 지정한 스프레드시트에서 오늘 기준으로 가장 최근 MMDD 시트를 탐색해 반환.
 * 어제부터 최대 maxDaysBack 일 전까지 역방향으로 탐색.
 * 해당 범위 내 시트가 없으면 에러 throw.
 *
 * @param {GoogleAppsScript.Spreadsheet.Spreadsheet} ss  열린 스프레드시트 객체
 * @param {string} ssLabel  에러 메시지용 이름
 * @param {number} maxDaysBack  최대 탐색 일수 (기본 14일)
 * @returns {{ sheet: Sheet, sheetName: string }}
 */
function findMostRecentSheet(ss, ssLabel, maxDaysBack = 14) {
  const today = new Date();
  for (let i = 1; i <= maxDaysBack; i++) {
    const target = new Date(today);
    target.setDate(today.getDate() - i);
    const mm = String(target.getMonth() + 1).padStart(2, '0');
    const dd = String(target.getDate()).padStart(2, '0');
    const sheetName = mm + dd; // MMDD
    const s = ss.getSheetByName(sheetName);
    if (s) return { sheet: s, sheetName };
  }
  throw new Error(
    `[${ssLabel}] 최근 ${maxDaysBack}일 이내 MMDD 시트를 찾을 수 없습니다.\n` +
    `시트 목록: ${ss.getSheets().map(sh => sh.getName()).join(', ')}`
  );
}

